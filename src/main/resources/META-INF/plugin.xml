<idea-plugin>
  <id>com.intellij.plugin.applescript</id>
  <name>AppleScript Support</name>
  <vendor>Community</vendor>
  <description><![CDATA[
    AppleScript language support for JetBrains IDEs, including syntax highlighting, code completion, run configuration
    templates and AppleScript dictionary tooling.
  ]]></description>
  <depends>com.intellij.modules.lang</depends>

  <extensions defaultExtensionNs="com.intellij">
    <fileType name="AppleScript"
              implementationClass="com.intellij.plugin.applescript.AppleScriptFileType"
              fieldName="INSTANCE"
              language="AppleScript"
              extensions="scpt;applescript"/>
    <lang.parserDefinition language="AppleScript"
                            implementationClass="com.intellij.plugin.applescript.lang.parser.AppleScriptParserDefinition"/>
    <lang.formatter language="AppleScript"
                    implementationClass="com.intellij.plugin.applescript.lang.formatter.AppleScriptFormattingModelBuilder"/>
    <codeStyleSettingsProvider implementation="com.intellij.plugin.applescript.lang.formatter.settings.AppleScriptCodeStyleSettingsProvider"/>
    <langCodeStyleSettingsProvider implementation="com.intellij.plugin.applescript.lang.formatter.settings.AppleScriptLanguageCodeStyleSettingsProvider"/>
    <lang.syntaxHighlighterFactory language="AppleScript"
                                   implementationClass="com.intellij.plugin.applescript.lang.ide.highlighting.AppleScriptSyntaxHighlighterFactory"/>
    <lang.commenter language="AppleScript"
                    implementationClass="com.intellij.plugin.applescript.lang.ide.AppleScriptCommenter"/>
    <lang.braceMatcher language="AppleScript"
                       implementationClass="com.intellij.plugin.applescript.lang.ide.highlighting.AppleScriptPairedBraceMatcher"/>
    <lang.findUsagesProvider language="AppleScript"
                             implementationClass="com.intellij.plugin.applescript.lang.ide.findUsages.AppleScriptFindUsagesProvider"/>
    <lang.readWriteAccessDetector language="AppleScript"
                                  implementationClass="com.intellij.plugin.applescript.lang.ide.findUsages.AppleScriptReadWriteAccessDetector"/>
    <lang.refactoringSupport language="AppleScript"
                              implementationClass="com.intellij.plugin.applescript.lang.ide.refactoring.AppleScriptRefactoringSupportProvider"/>
    <lang.refactoringSupport language="AppleScript"
                              implementationClass="com.intellij.plugin.applescript.lang.ide.refactoring.AppleScriptElementRefactoringSupportProvider"/>
    <lang.elementDescriptionProvider language="AppleScript"
                                     implementationClass="com.intellij.plugin.applescript.lang.ide.findUsages.AppleScriptElementDescriptionProvider"/>
    <usageTypeProvider implementation="com.intellij.plugin.applescript.lang.ide.findUsages.AppleScriptUsageTypeProvider"/>
    <lang.documentationProvider language="AppleScript"
                                implementationClass="com.intellij.plugin.applescript.lang.ide.AppleScriptDocumentationProvider"/>
    <lang.psiStructureViewFactory language="AppleScript"
                                  implementationClass="com.intellij.plugin.applescript.lang.ide.structure.AppleScriptStructureViewFactory"/>
    <lang.structureViewExtension language="AppleScript"
                                  implementationClass="com.intellij.plugin.applescript.lang.ide.structure.AppleScriptStructureViewExtension"/>
    <annotator language="AppleScript"
               implementationClass="com.intellij.plugin.applescript.lang.ide.annotator.AppleScriptColorAnnotator"/>
    <lineMarkerProvider language="AppleScript"
                        implementationClass="com.intellij.plugin.applescript.lang.ide.highlighting.AppleScriptLineMarkerProvider"/>
    <completion.contributor language="AppleScript"
                            implementationClass="com.intellij.plugin.applescript.lang.ide.completion.KeywordCompletionContributor"/>
    <completion.contributor language="AppleScript"
                            implementationClass="com.intellij.plugin.applescript.lang.ide.completion.CommandCompletionContributor"/>
    <completion.contributor language="AppleScript"
                            implementationClass="com.intellij.plugin.applescript.lang.ide.completion.ApplicationNameCompletionContributor"/>
    <defaultLiveTemplatesProvider implementation="com.intellij.plugin.applescript.lang.ide.AppleScriptLiveTemplatesProvider"/>
    <liveTemplateContext implementation="com.intellij.plugin.applescript.lang.ide.AppleScriptTemplateContextType"/>
    <referencesSearch implementation="com.intellij.plugin.applescript.lang.ide.search.AppleScriptHandlerReferencesSearch"/>
    <referencesSearch implementation="com.intellij.plugin.applescript.lang.ide.search.AppleScriptDictionaryComponentReferencesSearch"/>
    <pom.declarationSearcher implementation="com.intellij.plugin.applescript.lang.ide.search.AppleScriptHandlerDeclarationSearcher"/>
    <colorSettingsPage implementationClass="com.intellij.plugin.applescript.lang.ide.highlighting.AppleScriptColorsAndFontsPage"/>
    <configurationType implementation="com.intellij.plugin.applescript.lang.ide.run.AppleScriptConfigurationType"/>
    <runConfigurationProducer implementation="com.intellij.plugin.applescript.lang.ide.run.AppleScriptConfigurationProducer"/>
    <!-- SDEF-14: headless smoke entry point. Activates only when
         -Didea.ApplicationStarter.command=applescript-smoke is set; dormant otherwise. -->
    <applicationStarter implementation="com.intellij.plugin.applescript.smoke.AppleScriptSmokeStarter"/>
  </extensions>

  <actions>
    <action id="AppleScript.NewFile"
            class="com.intellij.plugin.applescript.lang.ide.actions.CreateAppleScriptFileAction"
            text="AppleScript File"
            description="Create a new AppleScript file">
      <add-to-group group-id="NewGroup" anchor="after" relative-to-action="NewFile"/>
    </action>
    <action id="AppleScript.LoadDictionary"
            class="com.intellij.plugin.applescript.lang.ide.actions.LoadDictionaryAction"
            text="Load AppleScript Dictionary"
            description="Load AppleScript application dictionary">
      <add-to-group group-id="ToolsMenu" anchor="last"/>
    </action>
  </actions>
</idea-plugin>
