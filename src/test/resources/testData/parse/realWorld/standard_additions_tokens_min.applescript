(*
    PARSE-04 minimal fixture: Apple StandardAdditions object tokens as top-level
    primary expressions — current date, ASCII character N, ASCII number C, and
    path to <constant>. Each on its own statement so the RED error set names the
    exact SA construct. No tell block and no app dictionary required (D-07).
*)
set d to current date
set c to ASCII character 9
set n to ASCII number "A"
set p to path to applications folder
